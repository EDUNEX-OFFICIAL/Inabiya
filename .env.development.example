# Local dev — copy to `.env` when running `pnpm dev` while Docker prod may be up.
# Prod Docker uses 3001/4001; dev uses 3101/4101 to avoid EADDRINUSE.
# See /srv/scripts/PORT_REGISTRY.md — Inabiya port block.

NODE_ENV=development
APP_URL=http://127.0.0.1:3101
API_URL=http://127.0.0.1:4101
NEXT_PUBLIC_API_URL=http://127.0.0.1:4101
API_PORT=4101
WEB_PORT=3101
LOG_LEVEL=info

DATABASE_URL=postgresql://inabiya:inabiya@127.0.0.1:5433/inabiya?schema=public
REDIS_URL=redis://127.0.0.1:6381

JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars!

PAYMENT_PROVIDER=mock
