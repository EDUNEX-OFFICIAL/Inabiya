{
  "name": "inabiya",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm run --parallel --filter @inabiya/web --filter @inabiya/api --filter @inabiya/worker dev",
    "dev:web": "pnpm --filter @inabiya/web dev",
    "dev:api": "pnpm --filter @inabiya/api dev",
    "dev:worker": "pnpm --filter @inabiya/worker dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r --if-present run lint",
    "typecheck": "pnpm -r --if-present run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "prisma generate --schema=prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema=prisma/schema.prisma",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio --schema=prisma/schema.prisma",
    "test": "pnpm -r --if-present run test"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "prettier": "^3.3.3",
    "prisma": "^5.22.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
