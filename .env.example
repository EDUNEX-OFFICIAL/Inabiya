# Copy to .env (never commit .env)
#
# PORTS (see /srv/scripts/PORT_REGISTRY.md):
#   Docker prod (deploy-vps):  web 3001, api 4001  → use when containers run
#   Local pnpm dev:            web 3101, api 4101  → copy .env.development.example instead
# Do NOT use 3001/4001 for pnpm dev if inabiya-api / inabiya-web containers are up.

# --- App (Docker prod defaults below; for pnpm dev use .env.development.example) ---
NODE_ENV=development
APP_URL=http://127.0.0.1:3001
# Production public host example: APP_URL=https://inabiya.edunexservices.in
API_URL=http://127.0.0.1:4001
NEXT_PUBLIC_API_URL=http://127.0.0.1:4001
API_PORT=4001
WEB_PORT=3001
LOG_LEVEL=info
# Behind HTTPS (Caddy/Cloudflare): COOKIE_SECURE=true
COOKIE_SECURE=false

# --- Database (docker-compose postgres on 127.0.0.1:5433) ---
DATABASE_URL=postgresql://inabiya:inabiya@127.0.0.1:5433/inabiya?schema=public

# --- Redis (docker-compose redis on 127.0.0.1:6381) ---
REDIS_URL=redis://127.0.0.1:6381

# --- Auth (Phase 1) — email/password only (no Google/OAuth) ---
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars!
# Seeded test users after `pnpm db:seed` (password for all):
#   customer@test.inabiya / Password123!
#   commerce@test.inabiya / Password123!
#   writer@test.inabiya / Password123!

# --- Object storage (local disk media; real S3/MinIO SDK still deferred) ---
S3_ENDPOINT=http://127.0.0.1:9002
S3_REGION=us-east-1
S3_BUCKET=inabiya
S3_ACCESS_KEY_ID=inabiya
S3_SECRET_ACCESS_KEY=inabiyadev
S3_FORCE_PATH_STYLE=true
# Absolute path for uploaded bytes (Docker prod: /data/media volume)
MEDIA_LOCAL_ROOT=

# --- Email (Phase 1) ---
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@inabiya.local

# --- Payments (Phase 3+) — mock until project complete; production = Razorpay ---
PAYMENT_PROVIDER=mock
# Razorpay keys — fill when integrating post-project:
PAYMENT_KEY_ID=
PAYMENT_KEY_SECRET=
PAYMENT_WEBHOOK_SECRET=change-me-in-production
