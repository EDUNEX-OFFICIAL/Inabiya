# Copy to .env (never commit .env)

# --- App ---
NODE_ENV=development
APP_URL=http://localhost:3001
API_URL=http://localhost:4001
API_PORT=4001
WEB_PORT=3001
LOG_LEVEL=info

# --- Database (docker-compose postgres on 127.0.0.1:5433) ---
DATABASE_URL=postgresql://inabiya:inabiya@127.0.0.1:5433/inabiya?schema=public

# --- Redis (docker-compose redis on 127.0.0.1:6381) ---
REDIS_URL=redis://127.0.0.1:6381

# --- Auth (Phase 1) — placeholders only ---
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars

# --- Object storage (S3-compatible stub) ---
S3_ENDPOINT=http://127.0.0.1:9002
S3_REGION=us-east-1
S3_BUCKET=inabiya
S3_ACCESS_KEY_ID=inabiya
S3_SECRET_ACCESS_KEY=inabiyadev
S3_FORCE_PATH_STYLE=true

# --- Email (Phase 1) ---
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@inabiya.local

# --- Payments (Phase 3) — leave empty until provider chosen ---
PAYMENT_PROVIDER=
PAYMENT_KEY_ID=
PAYMENT_KEY_SECRET=
PAYMENT_WEBHOOK_SECRET=
